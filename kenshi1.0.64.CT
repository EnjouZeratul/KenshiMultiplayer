              <ShowAsHex>1</ShowAsHex>
              <VariableType>8 Bytes</VariableType>
              <Address>kenshi_x64.exe+A08</Address>
            </CheatEntry>
            <CheatEntry>
              <ID>240</ID>
              <Description>"角色属性基址3"</Description>
              <ShowAsHex>1</ShowAsHex>
              <VariableType>8 Bytes</VariableType>
              <Address>kenshi_x64.exe+A10</Address>
            </CheatEntry>
          </CheatEntries>
        </CheatEntry>
        <CheatEntry>
          <ID>3</ID>
          <Description>"通过按c开属性页面记录角色属性基址 (修改前先开启，记录了相应角色基址后关闭)"</Description>
          <Options moHideChildren="1"/>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>define(address_recordStatus,"kenshi_x64.exe"+6CED66)
define(bytes_recordStatus,F3 0F 10 B1 94 00 00 00)

fullaccess(kenshi_x64.exe,0x1000)
fullaccess(kenshi_x64.exe,0x1008)
fullaccess(kenshi_x64.exe,0x1016)

[ENABLE]

assert(address_recordStatus,bytes_recordStatus)
alloc(newmem_recordStatus,$1000,address_recordStatus)

label(code_recordStatus)
label(return_recordStatus)

newmem_recordStatus:

code_recordStatus:
mov [kenshi_x64.exe+A00],rcx
mov rcx,[rcx+08]
mov [kenshi_x64.exe+a08],rcx
mov rcx,[kenshi_x64.exe+a00]
mov rcx,[rcx+10]
mov [kenshi_x64.exe+a10],rcx
mov rcx,[kenshi_x64.exe+a00]
  movss xmm6,[rcx+000000CC]
  jmp return_recordStatus

address_recordStatus:
  jmp newmem_recordStatus
  nop
  nop
  nop
return_recordStatus:

[DISABLE]

address_recordStatus:
  db bytes_recordStatus
  // movss xmm6,[rcx+00000094]

dealloc(newmem_recordStatus)
</AssemblerScript>
