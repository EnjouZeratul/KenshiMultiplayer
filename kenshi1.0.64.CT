              <Description>"金钱设为  10万"</Description>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>define(address_money,"kenshi_x64.exe"+5b04f5)//8B 90 88 00 00 00 89 54 24 30 48 8d 15 d2 3f bf 00
define(bytes_money,8B 90 88 00 00 00)

[ENABLE]

assert(address_money,bytes_money)
alloc(newmem_money,32,address_money)

label(code_money)
label(return_money)

newmem_money:

code_money:
mov [rax+00000088], #100000
  mov edx,[rax+00000088]
  jmp return_money

address_money:
  jmp newmem_money
  nop
return_money:

[DISABLE]

address_money:
  db bytes_money
  // mov edx,[rax+00000088]

dealloc(newmem_money)
