<?xml version="1.0" encoding="utf-8"?>
<CheatTable CheatEngineTableVersion="45">
  <CheatEntries>
    <CheatEntry>
      <ID>225</ID>
      <Description>"男儿当自强(角色信息)"</Description>
      <Options moHideChildren="1"/>
      <GroupHeader>1</GroupHeader>
      <CheatEntries>
        <CheatEntry>
          <ID>237</ID>
          <Description>"通过鼠标左键选取角色记录角色属性基址 (修改前先开启，记录了相应角色基址后关闭)"</Description>
          <Options moHideChildren="1"/>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>define(address_lockHP,"kenshi_x64.exe"+6CEA99)//F3 0F 10 46 70 f3 0f 58
define(bytes_lockHP,F3 0F 10 46 70)
fullaccess(kenshi_x64.exe,0x1000)
fullaccess(kenshi_x64.exe,0x1008)
fullaccess(kenshi_x64.exe,0x1016)
[ENABLE]

assert(address_lockHP,bytes_lockHP)
alloc(newmem_lockHP,$1000,address_lockHP)

label(code_lockHP)
label(return_lockHP)

newmem_lockHP:

code_lockHP:
// 原指令 movss xmm0,[rsi+70] 表明 rsi 为角色指针，应使用 rsi 而非 rcx
mov [kenshi_x64.exe+a00],rsi
mov rax,[rsi+8]
mov [kenshi_x64.exe+a08],rax
mov rax,[rsi+10]
mov [kenshi_x64.exe+a10],rax
  movss xmm0,[rsi+70]
  jmp return_lockHP

address_lockHP:
  jmp newmem_lockHP
return_lockHP:

[DISABLE]

address_lockHP:
  db bytes_lockHP
  // movss xmm0,[rsi+70]

dealloc(newmem_lockHP)
</AssemblerScript>
          <CheatEntries>
            <CheatEntry>
              <ID>238</ID>
              <Description>"角色属性基址1"</Description>
              <ShowAsHex>1</ShowAsHex>
